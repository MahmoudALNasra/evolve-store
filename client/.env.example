# In production the SPA calls same-origin /api (leave unset or use relative /api).
# Local Vite only:
VITE_API_URL=http://localhost:5000/api
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
# Public site URL for canonical links, OG, and JSON-LD (no trailing slash)
# Dev: http://localhost:5173
# Production build on droplet: https://evolvepharmacy.com
VITE_SITE_URL=http://localhost:5173
# San Antonio, TX sales tax shown in cart/checkout
VITE_SALES_TAX_RATE=0.0825
