PORT=5000
MONGO_URI=mongodb://localhost:27017/estore
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=7d
CLIENT_URL=http://localhost:5173
# Extra admin password required to open/modify the Orders tab
ADMIN_ORDERS_PASSWORD=change-this-orders-password
# Public API base for magic login links in emails (production: https://evolvepharmacy.com)
API_PUBLIC_URL=http://localhost:5000
# Public canonical URL for SEO / bot HTML (production domain, no trailing slash)
SITE_URL=https://evolvepharmacy.com

# Crawler prerendering (production: SERVE_SPA is on when NODE_ENV=production)
# SERVE_SPA=true
# CLIENT_DIST_PATH=../client/dist
# Optional headless service for non-product pages (Prerender.io or self-hosted)
# PRERENDER_ENABLED=true
# PRERENDER_SERVICE_URL=https://service.prerender.io
# PRERENDER_TOKEN=your_prerender_token
# PRERENDER_PROTOCOL=https

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Safety net: periodically verifies pending Stripe Checkout sessions and sends missed order emails
# CHECKOUT_RECONCILIATION_ENABLED=true
# CHECKOUT_RECONCILIATION_INTERVAL_MS=60000

# Sales tax — San Antonio, TX default is 8.25%
SALES_TAX_RATE=0.0825

# Shippo — live shipping rates (use test key from Shippo dashboard)
SHIPPO_API_KEY=shippo_test_your_key_here
SHIP_FROM_NAME=Evolve Specialty Pharmacy & Wellness
SHIP_FROM_LINE1=19239 Stone Oak Pkwy Ste # 103
SHIP_FROM_CITY=San Antonio
SHIP_FROM_STATE=TX
SHIP_FROM_ZIP=78258
SHIP_FROM_PHONE=2105550100
SHIP_FROM_EMAIL=support@evolvepharmacy.com
SHIP_PARCEL_WEIGHT_LB=1
SHIP_PARCEL_LENGTH_IN=8
SHIP_PARCEL_WIDTH_IN=6
SHIP_PARCEL_HEIGHT_IN=4

# Transactional email — order confirmation & shipping emails
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Evolve Specialty Pharmacy & Wellness
SUPPORT_EMAIL=support@evolvepharmacy.com
NEW_ORDER_NOTIFY_EMAIL=info@evolvepharmacy.com
CONTACT_NOTIFY_EMAIL=info@evolvepharmacy.com

# Recommended on DigitalOcean: use an HTTPS email API because outbound SMTP is blocked.
RESEND_API_KEY=re_your_resend_api_key
EMAIL_API_TIMEOUT_MS=15000

# Optional SMTP fallback for local/dev or non-blocked hosts.
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your_zoho_app_specific_password

# Supabase — first-party analytics (Service Role Key: server only, never expose to client)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Optional: direct Postgres URI for npm run setup:analytics (Settings → Database → URI)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
# Set to true in local HTTP dev if Secure cookies are not set (production uses Secure automatically)
# ANALYTICS_COOKIE_SECURE=false

# Google Analytics 4 — Measurement Protocol (server-side purchase / checkout)
# Admin → Data Streams → [your stream] → Measurement Protocol API secrets → Create
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_API_SECRET=your_measurement_protocol_api_secret
# Optional tuning
# GA4_REQUEST_TIMEOUT_MS=8000
# GA4_MAX_RETRIES=3

# Inventory sync — Google Sheets pipeline (IMPORTRANGE in Sheets, not code)
# 1) Master: 1xlDAl... tab "Products" (source of truth — you edit here)
# 2) IMPORTRANGE → 1LKXER... tab "from MasterSheet(products)" (automatic in Google Sheets)
# 3) Website sync reads tab "from MasterSheet(products)"; stock writes go back to master "Products"
# 4) GMC feed: 1LKXER... tab "Sheet1"
INVENTORY_SYNC_ENABLED=false
INVENTORY_SYNC_ON_ORDERS=false
INVENTORY_SYNC_INTERVAL_MS=900000
# Only set true if IMPORTRANGE breaks and you need code to copy master → import tab
INVENTORY_SYNC_MASTER_FIRST=false
INVENTORY_MIN_CATEGORY_PRODUCT_COUNT=2
INVENTORY_OTHER_CATEGORY_NAME=Other Categories
INVENTORY_WEBHOOK_SECRET=change-this-shared-secret
GOOGLE_MASTER_SHEET_ID=1xlDAlbKki5lwI91_Jw1pTe6mhyxIwEmp2_tJ6vOYMag
GOOGLE_MASTER_SHEET_NAME=Products
GOOGLE_MASTER_RANGE=
GOOGLE_INVENTORY_SHEET_ID=1LKXERqfQUOssj3WadUxIgwoPdcOyRcJGf8itFwTnhjk
GOOGLE_INVENTORY_SHEET_NAME=from MasterSheet(products)
GOOGLE_INVENTORY_RANGE='from MasterSheet(products)'!A:O
GOOGLE_INVENTORY_STOCK_COLUMN=10
# Stock updates on sales write to master Products tab (IMPORTRANGE tab is read-only)
GOOGLE_STOCK_SHEET_ID=1xlDAlbKki5lwI91_Jw1pTe6mhyxIwEmp2_tJ6vOYMag
GOOGLE_STOCK_SHEET_NAME=Products
GOOGLE_MERCHANT_FEED_SHEET_ID=1LKXERqfQUOssj3WadUxIgwoPdcOyRcJGf8itFwTnhjk
GOOGLE_MERCHANT_FEED_SHEET_NAME=Sheet1
GOOGLE_MERCHANT_FEED_LINK_COLUMN=7
# Delay between Google Sheets writes (avoids 300/min quota); 250ms ≈ 240 writes/min
GOOGLE_SHEETS_WRITE_DELAY_MS=250
# Set false to skip Sheet1 link column updates during bulk sync (website still syncs)
INVENTORY_SYNC_SHEET1_LINKS=true
# Force full website restore from sheet (also used by inventory:restore-from-sheet)
# INVENTORY_SYNC_FORCE=true
# Read master Products tab directly instead of GMC import tab
# INVENTORY_SYNC_FROM_MASTER=true
# Keep website admin prices when running inventory:sync (off by default — sheet wins)
# INVENTORY_SYNC_PRESERVE_WEBSITE_PRICE=false
# OAuth refresh token (recommended for production when SA keys are blocked)
# Run once locally: npm run google:oauth-token
GOOGLE_OAUTH_CLIENT_ID=your_desktop_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_desktop_oauth_client_secret
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost
# Use either GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# or local Google ADC with `gcloud auth application-default login`
GOOGLE_USE_APPLICATION_DEFAULT=false
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_MERCHANT_ID=your_merchant_center_id
GOOGLE_MERCHANT_CONTENT_LANGUAGE=en
GOOGLE_MERCHANT_TARGET_COUNTRY=US
GOOGLE_MERCHANT_CHANNEL=online
GOOGLE_MERCHANT_CURRENCY=USD

# Blog generation — AI-assisted SEO articles (drafts only until admin publishes)
BLOG_GENERATION_ENABLED=false
BLOG_BATCH_LIMIT=10
BLOG_PUBLIC_BASE_PATH=/blog
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BLOG_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TIMEOUT_MS=90000
SERPER_API_KEY=your_serper_api_key
# SERPER_TIMEOUT_MS=15000
# IMAGE_AUDIT_TIMEOUT_MS=8000

# Product image enrichment (Serper + local /media storage)
# Images are stored as RELATIVE paths in MongoDB, e.g. /media/products/{slug}/file.jpg
# They work on your IP now and on https://evolvepharmacy.com after DNS — no DB rewrite needed.
#
# SITE_URL — canonical domain for SEO, sitemaps, emails (set to final domain when ready)
SITE_URL=https://evolvepharmacy.com
# PUBLIC_MEDIA_URL — optional override when building absolute image URLs for feeds/JSON-LD
# PUBLIC_MEDIA_URL=https://evolvepharmacy.com
# MEDIA_ROOT=/var/www/evolve-store/server/media
# PUBLIC_MEDIA_BASE_PATH=/media
# PRODUCT_IMAGE_MIN_COUNT=5
# PRODUCT_IMAGE_MAX_COUNT=8
# PRODUCT_IMAGE_BATCH_LIMIT=25
# PRODUCT_IMAGE_SERPER_DELAY_MS=600
# IMAGE_DOWNLOAD_TIMEOUT_MS=25000
